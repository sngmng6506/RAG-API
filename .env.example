# ================================
# ChromaDB
# ================================
CHROMA_HOST=localhost
CHROMA_PORT=8003
CHROMA_COLLECTION_NAME=default

# ================================
# TEI (Text Embeddings Inference)
# ================================
TEI_HOST=<TEI 서버 IP>
TEI_PORT=8080

# ================================
# vLLM - LLM (gpt-oss-20b)
# ================================
VLLM_LLM_HOST=<vLLM 서버 IP>
VLLM_LLM_PORT=8000
VLLM_LLM_SERVED_MODEL_NAME=gpt-oss-20b

# ================================
# vLLM - Coder (Qwen2.5-Coder-7B-Instruct)
# ================================
VLLM_CODER_HOST=<vLLM 서버 IP>
VLLM_CODER_PORT=8001
VLLM_CODER_SERVED_MODEL_NAME=qwen2.5-coder-7b

# ================================
# App Settings
# ================================
APP_HOST=0.0.0.0
APP_PORT=9000
LOG_LEVEL=INFO
